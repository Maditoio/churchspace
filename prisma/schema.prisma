generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AGENT
  SUPER_ADMIN
}

enum ListingType {
  RENT
  HIRE
  SALE
  SHARING
}

enum PropertyType {
  SANCTUARY
  HALL
  CONFERENCE_ROOM
  OUTDOOR_SPACE
  VACANT_LAND
  FULL_PREMISES
  OTHER
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  SOLD
  SUSPENDED
}

enum ListingPaymentStatus {
  UNPAID
  PAID
  EXPIRED
}

enum AvailabilityType {
  ALWAYS
  SCHEDULED
  BY_REQUEST
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  phone         String?
  whatsapp      String?
  avatar        String?
  avatarThumb   String?
  role          Role      @default(USER)
  churchName    String?
  denomination  String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  listings      Listing[]
  listingPayments ListingPayment[]
  sessions      Session[]
  accounts      Account[]
  savedListings SavedListing[]
  sentEnquiries Enquiry[] @relation("EnquirySender")
  searchPreferences UserSearchPreference[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Listing {
  id                String           @id @default(cuid())
  title             String
  slug              String           @unique
  description       String
  propertyType      PropertyType
  listingType       ListingType[]
  status            ListingStatus    @default(DRAFT)
  address           String
  suburb            String
  city              String
  province          String
  country           String           @default("South Africa")
  latitude          Float?
  longitude         Float?
  congregationSize  Int?
  areaSquareMeters  Float?
  parkingSpaces     Int?
  rentPricePerHour  Decimal?         @db.Decimal(10, 2)
  rentPricePerDay   Decimal?         @db.Decimal(10, 2)
  rentPricePerMonth Decimal?         @db.Decimal(10, 2)
  salePrice         Decimal?         @db.Decimal(12, 2)
  depositAmount     Decimal?         @db.Decimal(10, 2)
  availabilityType  AvailabilityType @default(BY_REQUEST)
  availableFrom     DateTime?
  availableTo       DateTime?
  equipment         Json             @default("[]")
  features          Json             @default("[]")
  sharingSchedule   Json?
  images            ListingImage[]
  viewCount         Int              @default(0)
  paymentStatus     ListingPaymentStatus @default(UNPAID)
  paymentPaidAt     DateTime?
  paymentExpiresAt  DateTime?
  isTaken           Boolean          @default(false)
  takenAt           DateTime?
  isFeatured        Boolean          @default(false)
  adminNotes        String?
  rejectionReason   String?
  agent             User             @relation(fields: [agentId], references: [id])
  agentId           String
  savedBy           SavedListing[]
  enquiries         Enquiry[]
  notifications     Notification[]
  slots             AvailabilitySlot[]
  payments          ListingPayment[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status])
  @@index([city, suburb])
  @@index([agentId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  listingId String?
  title     String
  message   String
  reason    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  readAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([listingId])
  @@index([isRead])
}

model ListingPayment {
  id         String              @id @default(cuid())
  listingId  String
  userId     String
  amount     Decimal             @db.Decimal(10, 2)
  currency   String              @default("ZAR")
  status     ListingPaymentStatus @default(PAID)
  provider   String              @default("SIMULATED")
  reference  String              @unique
  paidAt     DateTime            @default(now())
  expiresAt  DateTime
  createdAt  DateTime            @default(now())
  listing    Listing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([userId])
  @@index([status])
}

model ListingImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())
}

model SavedListing {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model Enquiry {
  id          String   @id @default(cuid())
  message     String
  senderName  String
  senderEmail String
  senderPhone String?
  isRead      Boolean  @default(false)
  listing     Listing  @relation(fields: [listingId], references: [id])
  listingId   String
  sender      User?    @relation("EnquirySender", fields: [senderId], references: [id])
  senderId    String?
  createdAt   DateTime @default(now())
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  listingId String
  dayOfWeek Int
  startTime String
  endTime   String
  isBooked  Boolean  @default(false)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model UserSearchPreference {
  id                       String       @id @default(cuid())
  userId                   String
  fingerprint              String
  query                    String?
  city                     String?
  suburb                   String?
  propertyType             PropertyType?
  listingType              ListingType?
  lastSearchedAt           DateTime     @default(now())
  lastRecommendationSentAt DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  user                     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastSearchedAt])
  @@unique([userId, fingerprint])
}
